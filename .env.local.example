NEXT_PUBLIC_GA_ID=
# Google AdSense yayıncı kimliği (ca-pub-XXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT=

# ── İletişim (opsiyonel — boşsa config.ts'deki varsayılan kullanılır) ──
